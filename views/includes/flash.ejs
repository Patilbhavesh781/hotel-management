<% if(success && success.length > 0) { %>
    <div class="d-flex justify-content-center">
        <div class="alert alert-success alert-dismissible fade show col-lg-8 col-md-10 col-11 " role="alert">
            <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
        </div>
    </div>
<% } %>

<% if(error && error.length > 0) { %>
    <div class="d-flex justify-content-center">
        <div class="alert alert-danger alert-dismissible fade show col-lg-8 col-md-10 col-11 " role="alert">
            <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
        </div>
    </div>
<% } %>