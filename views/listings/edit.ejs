<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center mt-3">
    <div class="col-12 col-md-10 col-lg-8 fade-in-right-normal">
        <h3 class="text-center">Edit Your Listings</h3>
        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control" required>
                <div class="valid-feedback">Title Looks Good</div>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea type="text" name="listing[description]" class="form-control" required><%= listing.description %></textarea>
                <div class="invalid-feedback">Plese Enter Short Description</div>
            </div>
            <div class="mb-3" >
                Original Listing Image <br>
                <img src="<%= listing.image[0].url %>" alt="original image" style="height: 8rem;">
            </div>
            <div class="mb-3">
                <label for="image" class="form-label">If Want Change Upload 5 New Images</label>
                <input type="file" name="listing[image]" multiple value="<%= listing.image %>" class="form-control">
            </div>
            <div class="row">
                <div class="mb-3 col-12 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <input type="number" name="listing[price]" value="<%= listing.price %>" class="form-control" required>
                    <div class="invalid-feedback">Plese Enter Valid Price</div>
                </div>
                
                <div class="mb-3 col-12 col-md-8">
                    <label for="price" class="form-label">Country</label>
                    <input type="text" name="listing[country]" value="<%= listing.country %>" class="form-control" required>
                    <div class="invalid-feedback">Plese Enter Country</div>
                </div>
            </div>
            <div class="mb-3">
                <label for="location" class="form-label">Location</label>
                <input type="text" name="listing[location]" value="<%= listing.location %>" class="form-control" required>
                <div class="invalid-feedback">Plese Enter Location</div>
            </div>
            <div class="d-grid mt-3">
                <button class="btn btn-dark edit-btn ">Edit</button>
            </div>
           <br><br>
        </form>
    </div>
</div>
