<% layout("/layouts/boilerplate") %>


<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="row mt-3 justify-content-center">
    <!-- Main Card -->
    <div class="card col-12 mb-1 listing-card slide-in-right-normal">
        <h3 class="mb-2"><%= listing.title %></h3>

        <div id="carouselExampleIndicators" class="carousel slide mt-2" data-bs-ride="carousel" data-bs-interval="2000">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="2" aria-label="Slide 3"></button>
            <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="3" aria-label="Slide 4"></button>
            <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="4" aria-label="Slide 5"></button>
        </div>
        <div class="carousel-inner rounded-4">
            <div class="carousel-item active h-50">
            <img src="<%= listing.image[0].url %>" class="d-block w-100 " alt="...">
            </div>
            <div class="carousel-item h-50">
            <img src="<%= listing.image[1].url %>" class="d-block w-100 " alt="...">
            </div>
            <div class="carousel-item h-50">
            <img src="<%= listing.image[2].url %>" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item h-50">
            <img src="<%= listing.image[3].url %>" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item h-50">
            <img src="<%= listing.image[4].url %>" class="d-block w-100" alt="...">
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
        </div>

        <div class="card-body">
            <!-- Image Grid -->
            <div class="row g-2 one-row-image">
                <!-- Left Big Image -->
                <div class="col-12 col-md-6">
                    <div class="show-img ratio ratio-4x3">
                        <img src="<%= listing.image[0].url %>" alt="img" class="w-100 h-100 object-fit-cover" style="border-top-left-radius: 1.5rem; border-bottom-left-radius: 1.5rem;">
                    </div>
                </div>

                <!-- Right 2x2 Images -->
                <div class="col-12 col-md-6">
                    <div class="row g-2 h-100">
                        <div class="col-6">
                            <div class="show-img ratio ratio-4x3">
                                <img src="<%= listing.image[1].url %>" alt="img" class="w-100 h-100 object-fit-cover" >
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="show-img ratio ratio-4x3">
                                <img src="<%= listing.image[2].url %>" alt="img" class="w-100 h-100 object-fit-cover" style="border-top-right-radius: 1.5rem;">
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="show-img ratio ratio-4x3">
                                <img src="<%= listing.image[3].url %>" alt="img" class="w-100 h-100 object-fit-cover">
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="show-img ratio ratio-4x3">
                                <img src="<%= listing.image[4].url %>" alt="img" class="w-100 h-100 object-fit-cover" style="border-bottom-right-radius: 1.5rem;">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Listing Details -->
            <p class="card-text mt-3">
                <h5>Hosted By: <%= listing.owner.username %></h5>
                <hr>
                <strong>Description:</strong> <%= listing.description %><br><br>
                <strong>Price:</strong> <b>&#8377;</b><%= listing.price.toLocaleString("en-IN") %><br>
                <strong>Location:</strong> <%= listing.location %><br>
                <strong>Country:</strong> <%= listing.country %><br>
            </p>
        </div>
    </div>

    <!-- Edit/Delete Buttons -->
    <% if (currUser) { %>
        <% if(currUser.email == "rohitvadnere20003@gmail.com" || currUser._id.equals(listing.owner._id)) { %>
        <div class="btns col-12 col-md-12 col-lg-12 slide-in-right-normal mb-2">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn">Edit</a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
                <button class="btn btn-dark ms-2">Delete</button>
            </form>
        </div>
        <hr class="mt-2">
        <% } %>
    <% } %>

    <!-- Review Section -->
    <div class="col-md-9 col-lg-7 slide-in-right-normal">
        <% if (currUser) { %>
            <h4>Leave a Review</h4>
            <form method="POST" action="/listings/<%= listing.id %>/reviews" novalidate class="needs-validation">
                <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating</label>
                    <fieldset class="starability-slot">
                        <input type="radio" id="rate1" name="review[rating]" value="1" checked />
                        <label for="rate1" title="Terrible">1 star</label>

                        <input type="radio" id="rate2" name="review[rating]" value="2" />
                        <label for="rate2" title="Not good">2 stars</label>

                        <input type="radio" id="rate3" name="review[rating]" value="3" />
                        <label for="rate3" title="Average">3 stars</label>

                        <input type="radio" id="rate4" name="review[rating]" value="4" />
                        <label for="rate4" title="Very good">4 stars</label>

                        <input type="radio" id="rate5" name="review[rating]" value="5" />
                        <label for="rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>

                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comments</label>
                    <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
                    <div class="invalid-feedback">Please Add Comments For Review</div>
                </div>

                <div>
                    <button class="btn btn-outline-dark">Submit</button>
                </div>
            </form>
        <% } %>

        <!-- All Reviews -->
        
        <% if (listing.reviews.length > 0) { %>
            <hr>
            <p><b>All Reviews</b></p>
            <div class="row justify-content-center">
                <% for (let review of listing.reviews) { %>
                    <div class="card col-10 col-sm-5 col-md-5 col-lg-5 mb-3 ms-3 pb-5">
                        <div class="card-body mb-2">
                            <h5 class="card-title">@<%= review.author.username %></h5>
                            <p class="starability-result" data-rating="<%= review.rating %>"></p>
                            <p class="card-text"><%= review.comment %></p>
                        </div>
                        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="position-absolute bottom-0 mb-2">
                            <button class="btn btn-sm btn-dark">Delete</button>
                        </form>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>

    <!-- Map Section -->
    <div class="col-11 col-md-12 col-lg-12 mt-2">
        <hr>
        <h3>Where You'll be</h3>
        <div id="map"></div>
    </div>
</div>

<br><br>
<script src="/js/map.js"></script>
